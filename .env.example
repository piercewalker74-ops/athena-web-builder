# ─────────────────────────────────────────────────────────────────────────────
# Athena Web Builder — environment template.
# Copy this file to  backend/.env.local  and fill in your own values.
# NEVER commit the filled-in file. Everything here is optional; the app boots
# with sensible localhost defaults and features light up as you configure them.
# ─────────────────────────────────────────────────────────────────────────────

# --- Core server ---
PORT=3001
# Where the frontend is served from (CORS allow-origin).
FRONTEND_ORIGIN=http://localhost:5173
# Public base URL used when composing outreach links. Defaults to localhost.
PUBLIC_BASE_URL=http://localhost:3001

# --- Agent backend (REQUIRED to actually run builds) ---
# The build runner shells out to the `openclaw` agent CLI and talks to its local
# gateway. Install and configure OpenClaw separately, then point these at it.
# Without it, the UI runs but the build pipeline cannot launch jobs.
NEOFORM_MODEL=claude-cli/claude-opus-4-8
NEOFORM_TIMEOUT_S=7200
# Set to "off" to fill the build queue without spawning agents.
NEOFORM_RUNNER=on

# --- Site template (the starter the builder scaffolds each site from) ---
# Path to your Next/Vite site template. Relative to the backend cwd or absolute.
SITE_TEMPLATE_PATH=../neoform-site-template

# --- Deploys (optional — Vercel) ---
VERCEL_TOKEN=
VERCEL_SCOPE=

# --- Reporting: Telegram (optional) ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_OWNER_CHAT_ID=
TELEGRAM_PARTNER_CHAT_ID=

# --- Outreach: Twilio SMS (optional) ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# --- Remote access gate (optional) ---
# If you publish the backend behind a tunnel, set a password for HTTP Basic Auth
# on tunneled requests. Localhost stays open.
ATHENA_REMOTE_PASSWORD=
